# ── Primary AI ────────────────────────────────────────────────────────────────
K2_API_KEY=your_k2_key_here
K2_BASE_URL=https://api.k2think.ai/v1
K2_MODEL=MBZUAI-IFM/K2-Think-v2

# ── Gemini Fallback ───────────────────────────────────────────────────────────
# If K2 errors during demo, the backend can fail over to Gemini automatically.
ENABLE_GEMINI_FALLBACK=true
GEMINI_API_KEY=your_gemini_key_here
# Legacy alias supported by the backend if you want to reuse older env files.
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Voice ─────────────────────────────────────────────────────────────────────
# ElevenLabs is the primary TTS provider.
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5

# Keep Kokoro fallback off on low-memory hosts like Render unless you explicitly
# want the server to load local TTS weights after ElevenLabs fails.
ENABLE_KOKORO_FALLBACK=false

# Kokoro powers the optional local fallback text-to-speech path.
KOKORO_VOICE=af_heart
KOKORO_LANG_CODE=a
KOKORO_SPEED=1.0

# Optional Hugging Face token for faster Kokoro model downloads / higher limits.
HF_TOKEN=
