# ── Primary AI ────────────────────────────────────────────────────────────────
K2_API_KEY=your_k2_key_here
K2_BASE_URL=https://api.k2think.ai/v1
K2_MODEL=MBZUAI-IFM/K2-Think-v2

# ── Gemini Fallback ───────────────────────────────────────────────────────────
# If K2 errors during demo, the backend can fail over to Gemini automatically.
ENABLE_GEMINI_FALLBACK=true
GEMINI_API_KEY=your_gemini_key_here
# Legacy alias supported by the backend if you want to reuse older env files.
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Voice ─────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5
